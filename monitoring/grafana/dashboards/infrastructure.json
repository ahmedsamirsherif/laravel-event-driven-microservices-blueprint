{
  "annotations": {"list": []},
  "description": "Infrastructure health — Service status, Redis cache, RabbitMQ resources",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 100, "title": "Service Health", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "mappings": [{"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}]}, "overrides": []},
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 1},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"},
      "targets": [{"expr": "up{job=\"hr-service\"}", "refId": "A"}],
      "title": "HR Service",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "mappings": [{"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}]}, "overrides": []},
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"},
      "targets": [{"expr": "up{job=\"hub-service\"}", "refId": "A"}],
      "title": "Hub Service",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "mappings": [{"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}]}, "overrides": []},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 1},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "value"},
      "targets": [{"expr": "up{job=\"rabbitmq\"}", "refId": "A"}],
      "title": "RabbitMQ",
      "type": "stat"
    },

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}, "id": 101, "title": "Cache Performance", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 50}, {"color": "green", "value": 80}]}, "unit": "percent", "decimals": 1}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 6},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "targets": [{"expr": "sum(rate(app_cache_hits_total[5m])) / (sum(rate(app_cache_hits_total[5m])) + sum(rate(app_cache_misses_total[5m]))) * 100", "refId": "A"}],
      "title": "Cache Hit Rate",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"fillOpacity": 15}, "unit": "ops"}, "overrides": [
        {"matcher": {"id": "byName", "options": "Hits"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
        {"matcher": {"id": "byName", "options": "Misses"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
      ]},
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 6},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum(rate(app_cache_hits_total[5m]))", "legendFormat": "Hits", "refId": "A"},
        {"expr": "sum(rate(app_cache_misses_total[5m]))", "legendFormat": "Misses", "refId": "B"}
      ],
      "title": "Cache Hits vs Misses",
      "type": "timeseries"
    },

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}, "id": 102, "title": "RabbitMQ Resources", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 15},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {"expr": "rabbitmq_process_resident_memory_bytes", "legendFormat": "Resident Memory", "refId": "A"},
        {"expr": "rabbitmq_resident_memory_limit_bytes", "legendFormat": "Memory Limit", "refId": "B"}
      ],
      "title": "RabbitMQ Memory",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 15},
      "id": 7,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "rabbitmq_erlang_processes_used", "legendFormat": "Processes Used", "refId": "A"},
        {"expr": "rabbitmq_erlang_processes_limit", "legendFormat": "Processes Limit", "refId": "B"}
      ],
      "title": "Erlang Processes",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 15},
      "id": 8,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "rabbitmq_disk_space_available_bytes", "legendFormat": "Available Disk", "refId": "A"},
        {"expr": "rabbitmq_disk_space_available_limit_bytes", "legendFormat": "Disk Limit", "refId": "B"}
      ],
      "title": "RabbitMQ Disk Space",
      "type": "timeseries"
    },

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23}, "id": 103, "title": "Service Uptime", "type": "row"},
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10}, "unit": "short", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 24},
      "id": 9,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"expr": "up", "legendFormat": "{{job}}", "refId": "A"}],
      "title": "Service Up/Down History",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["hr-platform", "infrastructure"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s",
  "title": "Infrastructure Health",
  "uid": "infrastructure",
  "version": 1
}
