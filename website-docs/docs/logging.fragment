      <tr><td><code>info</code></td><td>EmployeeUpdated handled</td><td><code>employee_id</code>, <code>country</code></td></tr>
      <tr><td><code>info</code></td><td>EmployeeDeleted handled</td><td><code>employee_id</code>, <code>country</code></td></tr>
