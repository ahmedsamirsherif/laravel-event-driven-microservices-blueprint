    <tbody>
      <tr><td><code>RabbitMQPublisher</code></td><td><code>info</code></td><td>Event published</td><td><code>routing_key</code>, <code>event_id</code></td></tr>
      <tr><td><code>RabbitMQPublisher</code></td><td><code>error</code></td><td>Failed to publish event</td><td><code>routing_key</code>, <code>event_id</code>, <code>error</code></td></tr>
      <tr><td><code>PublishEmployeeEventToRabbitMQ</code></td><td><code>error</code></td><td>Failed to publish employee event</td><td><code>event_type</code>, <code>employee_id</code>, <code>error</code></td></tr>
