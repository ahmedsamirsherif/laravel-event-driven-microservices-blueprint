  <h3>Middleware &amp; Exceptions</h3>
  <table>
    <thead><tr><th>File</th><th>Level</th><th>Message</th><th>Context</th></tr></thead>
    <tbody>
      <tr><td><code>AddRequestId</code></td><td>context</td><td><em>(sets request_id on all logs)</em></td><td><code>request_id</code></td></tr>
      <tr><td><code>RecordRequestMetrics</code></td><td><code>warning</code></td><td>Request metrics recording failed</td><td><code>method</code>, <code>endpoint</code>, <code>status</code>, <code>error</code></td></tr>
      <tr><td><code>Handler</code></td><td><code>error</code></td><td>Unhandled exception</td><td><code>exception</code> (class name), <code>message</code></td></tr>
    </tbody>
  </table>

