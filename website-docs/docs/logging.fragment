      <tr><td><code>error</code></td><td>Failed to process RabbitMQ message</td><td><code>event_type</code>, <code>retry_count</code>, <code>error</code></td></tr>
      <tr><td><code>info</code></td><td>Message re-queued for retry</td><td><code>retry_count</code>, <code>delay_ms</code></td></tr>
      <tr><td><code>warning</code></td><td>Message exhausted retries, sending to DLQ</td><td><code>event_type</code>, <code>retry_count</code></td></tr>
    </tbody>
  </table>

